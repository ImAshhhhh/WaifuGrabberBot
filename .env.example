# ─── Core bot config ────────────────────────────────────────────
BOT_TOKEN=123456:ABC-DEF_your_bot_token_from_botfather
BOT_USERNAME=WaifuGrabberrBot

# ─── Database (Postgres — required for 10k concurrent users) ───
# Note: asyncpg wants plain 'postgresql://' (NOT 'postgresql+asyncpg://')
DATABASE_URL=postgresql://waifu:waifu_pass@localhost:5432/waifugrabber
PG_POOL_MIN=10
PG_POOL_MAX=30

# ─── Redis (caching, rate limiting, leaderboards, active spawns) ─
REDIS_URL=redis://localhost:6379/0

# ─── Webhook mode (production) vs long polling (dev) ────────────
USE_WEBHOOK=false
WEBHOOK_URL=https://your-domain.com/bot
WEBHOOK_PATH=/bot
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8443

# ─── Game tuning ────────────────────────────────────────────────
SPAWN_MSG_INTERVAL=100        # spawn every N group messages
SPAWN_TIME_FLOOR=300          # OR every N seconds (whichever first)
SPAWN_CLAIM_WINDOW=90         # seconds before spawn escapes
GUESS_COOLDOWN=3              # seconds between /guess attempts per user
TRADE_WINDOW=60               # seconds to accept a trade

# ─── Owner / admin ──────────────────────────────────────────────
OWNER_ID=7269251740           # your Telegram user ID (from @userinfobot)

# ─── Logging ────────────────────────────────────────────────────
LOG_LEVEL=INFO
